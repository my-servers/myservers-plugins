{
  "id": "myservers-demo-nas",
  "version": "1.0.24",
  "name": "NAS 示例插件",
  "description": "用于验证插件市场、配置表单、Goja 渲染和点击动作的示例插件。",
  "icon": "shippingbox.fill",
  "demo_card": {
    "background_colors": ["#4338CA", "#7C3AED", "#0F172A"],
    "overlay_opacity": 0.42,
    "hero": {
      "icon": "square.grid.2x2.fill",
      "title": "组件控制台",
      "subtitle": "插件安装后的 Dashboard 预览"
    },
    "highlights": [
      { "icon": "square.stack.3d.up.fill", "label": "组件", "value": "31" },
      { "icon": "rectangle.bottomhalf.inset.filled", "label": "半弹层", "value": "3 档" },
      { "icon": "bolt.shield.fill", "label": "Action", "value": "受控" }
    ]
  },
  "min_server_version": "3.0.22",
  "min_app_version": "3.20",
  "permissions": [],
  "config_schema": [
    {
      "key": "host_label",
      "label": "显示名称",
      "description": "显示在 dashboard 和详情页里的 NAS 名称。",
      "placeholder": "例如：客厅 NAS",
      "input": "text",
      "required": false,
      "default_value": "NAS"
    },
    {
      "key": "accent",
      "label": "强调色",
      "description": "用于卡片和图表的强调色。",
      "input": "select",
      "required": false,
      "default_value": "blue",
      "options": [
        { "label": "蓝色", "value": "blue" },
        { "label": "绿色", "value": "green" },
        { "label": "紫色", "value": "purple" }
      ]
    }
  ],
  "commands": [],
  "entrypoints": { "main": "main.js" },
  "assets": [
    {
      "path": "main.js",
      "kind": "script",
      "url": "https://raw.githubusercontent.com/my-servers/myservers-plugins/main/plugins/myservers-demo-nas/1.0.23/main.js"
    }
  ],
  "checksums": {
    "main.js": "sha256:d486d1822f8826c678fcb3951e9b9ccd0031ca6c0c7a7da6a7457c48733047f9"
  },
  "widgets": [
    {
      "id": "summary",
      "name": "NAS 示例小组件",
      "description": "展示插件返回的通用组件数据。"
    }
  ],
  "background_tasks": [
    {
      "id": "refresh-demo",
      "name": "刷新示例数据",
      "interval_ms": 60000
    }
  ]
}
