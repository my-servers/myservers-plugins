    "latest_version": "1.0.35",
    "manifest_path": "plugins/myservers-demo-nas/1.0.35/manifest.json"
  },
  {
    "id": "cloudflare-overview",
    "name": "Cloudflare 概览",
    "description": "集中查看 Cloudflare 域名、子域名流量、DNS 与 Tunnel 状态。",
    "icon": "cloud.fill",
    "icon_url": "https://www.cloudflare.com/favicon.ico",
    "demo_cards": [
      {
        "style": "components",
        "description": "流量趋势",
