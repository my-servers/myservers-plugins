            "subtitle": "A · AAAA · CNAME · MX",
            "icon": "globe",
            "accent": "indigo",
            "value": 24
          },
          {
            "kind": "donut",
            "title": "代理状态",
            "icon": "cloud.fill",
            "accent": "orange",
            "points": [
              { "label": "已代理", "value": 18 },
              { "label": "仅 DNS", "value": 6 }
            ]
          }
        ]
      },
      {
        "style": "components",
        "description": "Tunnel 健康度",
        "dashboard_title": "Cloudflare Tunnel",
        "badge_text": "远程访问",
        "action_title": "查看连接",
        "background_colors": ["#0F766E", "#115E59", "#111827"],
        "overlay_opacity": 0.5,
        "hero": {
          "icon": "point.3.connected.trianglepath.dotted",
          "title": "Tunnel 连接状态",
          "subtitle": "查看 NAS 与 Cloudflare Edge 的连接健康度"
