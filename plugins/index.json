        "components": [
          { "kind": "badge", "text": "全部在线", "accent": "green" },
          {
            "kind": "gauge",
            "title": "Tunnel 健康度",
            "icon": "point.3.connected.trianglepath.dotted",
            "accent": "teal",
            "min": 0,
            "max": 100,
            "points": [{ "label": "健康", "value": 100 }]
          },
          {
            "kind": "value",
            "title": "在线连接",
            "subtitle": "3 个 Tunnel",
            "icon": "link.circle.fill",
            "accent": "green",
            "value": 3
          }
        ]
      }
    ],
    "latest_version": "1.0.20",
    "manifest_path": "plugins/cloudflare-overview/1.0.20/manifest.json"
  },
